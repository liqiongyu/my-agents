  "maturity": "experimental",
  "categories": ["workflow", "coding"],
  "tags": ["issue", "orchestration", "github", "codex", "issue-agent-os"],
  "authors": [
    {
      "name": "Qiongyu Li"
    }
  ],
  "archetype": "custom",
  "agents": ["triager", "planner", "coder", "reviewer", "debugger", "splitter"],
  "capabilities": {
    "shell": true,
    "network": true,
    "filesystemRead": true,
    "filesystemWrite": true
  }
}
