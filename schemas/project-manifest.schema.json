{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/liqiongyu/my-agents/main/schemas/project-manifest.schema.json",
  "title": "Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "$defs": {
    "localNameEntry": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "externalBaseEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "provider",
        "platform",
        "name",
        "repo",
        "declaredRef",
        "resolvedCommit",
        "path",
        "sourceUrl"
      ],
      "properties": {
        "source": {
          "type": "string",
          "const": "official"
        },
        "provider": {
          "type": "string",
          "const": "github"
        },
        "platform": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "declaredRef": {
          "type": "string",
          "minLength": 1
        },
        "resolvedCommit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*//).+[^/]$"
        },
        "sourceUrl": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github\\.com/"
        }
      }
    },
    "externalSkillEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/externalBaseEntry"
        },
        {
          "properties": {
            "platform": {
              "const": "claude"
            }
          }
        }
      ]
    },
    "externalClaudeAgentEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/externalBaseEntry"
        },
        {
          "properties": {
            "platform": {
              "const": "claude"
            },
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*//).+\\.md$"
            }
          }
        }
      ]
    },
    "externalCodexAgentEntry": {
      "allOf": [
        {
          "$ref": "#/$defs/externalBaseEntry"
        },
        {
          "properties": {
            "platform": {
              "const": "codex"
            },
            "path": {
              "type": "string",
              "pattern": "^(?!/)(?!.*//).+\\.toml$"
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude", "codex"]
      }
    },
    "packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/localNameEntry"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/localNameEntry"
          },
          {
            "$ref": "#/$defs/externalSkillEntry"
          }
        ]
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/localNameEntry"
          },
          {
            "$ref": "#/$defs/externalClaudeAgentEntry"
          },
          {
            "$ref": "#/$defs/externalCodexAgentEntry"
          }
        ]
      }
    }
  }
}
