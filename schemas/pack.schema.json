{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/liqiongyu/my-agents/main/schemas/pack.schema.json",
  "title": "Pack Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "displayName",
    "description",
    "version",
    "maturity",
    "packType",
    "categories",
    "authors"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Pack 唯一标识（与目录名一致），建议 kebab-case。"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "description": "对外展示名称（可含空格/大小写）。"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "一句话描述，用于索引与搜索。"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "SemVer。"
    },
    "maturity": {
      "type": "string",
      "enum": ["experimental", "beta", "stable", "deprecated"]
    },
    "packType": {
      "type": "string",
      "enum": ["role-pack", "agent-team"],
      "description": "Pack 语义类型。"
    },
    "persona": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "目标角色或受众标识。"
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "description": "分类（建议小写 kebab-case）。"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "description": "显式包含的 skill 名称列表。"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "description": "显式包含的 agent 名称列表。"
    },
    "leadAgent": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "agent-team 的主 agent。"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/person"
      }
    },
    "contributors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/person"
      }
    },
    "maintainers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/person"
      }
    },
    "license": {
      "type": "string",
      "description": "可选：SPDX 标识或简短描述；为空表示继承仓库 License。"
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "issues": { "type": "string", "format": "uri" },
        "docs": { "type": "string", "format": "uri" }
      }
    },
    "deprecated": {
      "type": "boolean"
    },
    "replacedBy": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    }
  }
}
