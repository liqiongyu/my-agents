{
  "schemaVersion": 1,
  "name": "skill-lifecycle-manager",
  "displayName": "Skill Lifecycle Manager",
  "description": "Manage the lifecycle of agent skills: discover patterns, create or update a skill, validate it, evaluate it, project or install it, or audit a skill library. Use only for explicitly skill-focused requests.",
  "version": "0.4.1",
  "maturity": "experimental",
  "categories": [
    "workflow",
    "research",
    "productivity"
  ],
  "tags": [
    "skill-lifecycle",
    "skill-creation",
    "skill-validation",
    "skill-evaluation",
    "trigger-optimization",
    "skill-audit"
  ],
  "authors": [
    {
      "name": "Qiongyu Li"
    }
  ],
  "entrypoints": {
    "skillDoc": "SKILL.md",
    "changelog": "CHANGELOG.md"
  },
  "requirements": {
    "runtimes": {
      "node": ">=18",
      "python": ">=3.9"
    },
    "tools": [
      "git",
      "uv",
      "codex",
      "claude"
    ],
    "network": "optional"
  },
  "capabilities": {
    "shell": true,
    "network": true,
    "filesystemRead": true,
    "filesystemWrite": true
  }
}
