{
  "name": "@liqiongyu/my-agents",
  "version": "0.1.0",
  "description": "A monorepo for creating, managing, and publishing reusable Agent skills and sub-agent definitions.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build-catalog.js",
    "new": "node scripts/new.js",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:node": "node --test scripts/tests/*.test.js",
    "test:skill-lifecycle-manager": "uv run python skills/skill-lifecycle-manager/scripts/run_unit_tests.py",
    "check:staged": "node scripts/run-staged-checks.js",
    "prepare": "node scripts/setup-git-hooks.js",
    "sync-instructions": "node scripts/sync-instructions.js",
    "sync-references": "node scripts/sync-references.js",
    "validate": "npm run lint && npm run format:check && node scripts/sync-instructions.js --check && node scripts/validate.js && npm run test:node && npm run test:skill-lifecycle-manager",
    "install-skill": "node scripts/install.js --skill",
    "install-agent": "node scripts/install.js --agent",
    "install-pack": "node scripts/install.js --pack",
    "sync-project": "node scripts/install.js --sync-project",
    "uninstall-skill": "node scripts/install.js --skill --uninstall",
    "uninstall-agent": "node scripts/install.js --agent --uninstall",
    "uninstall-pack": "node scripts/install.js --pack --uninstall",
    "test": "npm run validate"
  },
  "bin": {
    "my-agents": "scripts/install.js",
    "my-agents-install": "scripts/install.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/liqiongyu/my-agents.git"
  },
  "keywords": [
    "agent-skills",
    "agents",
    "sub-agents",
    "claude-code",
    "codex",
    "llm",
    "prompt-engineering"
  ],
  "author": "Qiongyu Li",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.5.3"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
